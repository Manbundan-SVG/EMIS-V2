COINMARKETCAP_API_KEY=
COINMARKETCAP_BASE_URL=https://pro-api.coinmarketcap.com
CURRENCY_API_KEY=
CURRENCY_API_BASE_URL=https://api.currencyapi.com
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
