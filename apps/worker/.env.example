BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_SPOT_BASE_URL=https://api.binance.com
BYBIT_BASE_URL=https://api.bybit.com
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_DXY_SERIES_CODE=DTWEXBGS
FRED_US10Y_SERIES_CODE=DGS10
# Phase 4.0A: supplemental FRED series for multi-asset rates/macro path.
# US10Y and DXY remain owned by the existing macro_sync_service.
FRED_US2Y_SERIES_CODE=DGS2
FRED_YIELD_SPREAD_SERIES_CODE=T10Y2Y
MARKET_SYNC_TIMEOUT_SECONDS=15
MARKET_SYNC_QUOTE_ASSET=USDT
MARKET_SYNC_SYMBOL_OVERRIDES_JSON={}
# Phase 4.0A: multi-asset symbol coverage (JSON list or comma-separated).
# Primary providers:
#   equity/index/commodity ETF snapshots -> Alpaca  (ALPACA_API_KEY + ALPACA_SECRET_KEY)
#   FX latest rates                      -> CurrencyAPI (CURRENCY_API_KEY)
#   rates / macro proxies                -> FRED (FRED_API_KEY)
# If a provider key is missing, that asset class is skipped — there is no fabricated data.
MULTI_ASSET_EQUITY_SYMBOLS_JSON=["SPY","QQQ","DIA","IWM"]
MULTI_ASSET_COMMODITY_SYMBOLS_JSON=["GLD","USO"]
