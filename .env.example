# EMIS-V2 environment template.
# Copy to `.env` and fill in dev values for local development.
# The `.env` file is gitignored — never commit real credentials.
#
# Prod and staging values should ONLY exist in GitHub Actions secrets,
# never in any local `.env` file. The migration wrapper enforces this:
# `--env=prod --apply` is refused outside CI unless EMIS_ALLOW_PROD_FROM_LOCAL=1.

# ---------------------------------------------------------------------
# Migration target databases (used by scripts/safe_apply_migration.ts)
# ---------------------------------------------------------------------

# Dev: your local Supabase stack or your personal dev project.
SUPABASE_DB_URL_DEV=postgresql://postgres:postgres@localhost:54322/postgres

# Staging: leave blank locally. Provisioned via GitHub secret.
SUPABASE_DB_URL_STAGING=

# Prod: leave blank locally. Provisioned via GitHub secret.
# Setting this in a local `.env` is a policy violation.
SUPABASE_DB_URL_PROD=

# ---------------------------------------------------------------------
# Supabase MCP / dashboard linking (optional, dev only)
# ---------------------------------------------------------------------

# Project ref for the dev Supabase project (matches .mcp.json).
SUPABASE_PROJECT_REF=

# Personal access token — only needed for direct supabase CLI commands
# beyond `db push`. NOT used by the migration wrapper.
SUPABASE_ACCESS_TOKEN=

# ---------------------------------------------------------------------
# Wrapper overrides (use with care)
# ---------------------------------------------------------------------

# Allows --env=prod --apply outside CI. Emergency hotfixes only.
# Default: unset. Setting this in your shell is a deliberate, audited choice.
# EMIS_ALLOW_PROD_FROM_LOCAL=1
